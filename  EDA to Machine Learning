        "        'invalid_discount': ((df['discount'] < 0) | (df['discount'] > 1)).sum(),\n",
        "        'invalid_profit': df['profit'].isnull().sum(),\n",
        "        'invalid_shipping_cost': (df['shipping_cost'] < 0).sum(),\n",
        "\n",
